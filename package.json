{
  "name": "music",
  "version": "1.0.0",
  "description": "music 音乐桌面客户端重构版",
  "main": "src/main.js",
  "private": true,
  "author": "",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "server": "node src/server/index.js",
    "web:start": "node src/server/index.js",
    "serve:web": "node src/server/index.js",
    "test": "node --test tests/*.test.js",
    "test:pwa": "node scripts/check-pwa.js",
    "pwa:check": "node scripts/check-pwa.js",
    "probe:sources": "node scripts/probe-music-sources.js",
    "probe:backend": "node scripts/probe-backend.js",
    "qa:electron": "node scripts/qa-electron.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --dir",
    "build": "electron-builder --dir",
    "installer": "electron-builder"
  },
  "build": {
    "appId": "com.music.music",
    "productName": "music",
    "asar": true,
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "webroot",
        "to": "webroot"
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "music"
    }
  },
  "dependencies": {
    "@meting/core": "^1.6.1",
    "@unblockneteasemusic/server": "^0.28.0",
    "axios": "^1.13.2",
    "express": "^5.2.1",
    "multer": "^2.0.2",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "electron": "^38.5.1",
    "electron-builder": "^26.0.12"
  }
}
