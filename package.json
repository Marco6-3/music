{
  "name": "xcloud-music-rebuild",
  "version": "1.0.0",
  "description": "XCloud音乐桌面客户端重构版",
  "main": "src/main.js",
  "private": true,
  "author": "",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "server": "node scripts/run-server.js",
    "probe:sources": "node scripts/probe-music-sources.js",
    "probe:backend": "node scripts/electron-node.js scripts/probe-backend.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --dir",
    "build": "electron-builder --dir",
    "installer": "electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.xcloud.music",
    "productName": "XCloud音乐",
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/build/Release/*.node"
    ],
    "files": [
      "src/**/*",
      "webroot/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "webroot",
        "to": "webroot"
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "XCloud音乐"
    }
  },
  "dependencies": {
    "axios": "^1.13.2",
    "better-sqlite3": "^12.4.6",
    "express": "^5.2.1",
    "@meting/core": "^1.6.1",
    "multer": "^2.0.2"
  },
  "devDependencies": {
    "electron": "^38.5.1",
    "electron-builder": "^26.0.12"
  }
}
